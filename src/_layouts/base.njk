<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO Meta -->
    <meta name="description" content="{{ description }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:type" content="article">
    <meta property="og:url" content="https://cluenex.com{{ page.url }}">
    <meta property="og:site_name" content="Cluenex">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="author" content="Cluenex">
    <meta name="keywords" content="{{ keywords | join(', ') }}">
    <link rel="canonical" href="https://cluenex.com{{ page.url }}">

    <title>{{ title }} | Cluenex Learn</title>

    <link rel="icon" type="image/png" href="/assets/favicon.png">

    <!-- JSON-LD: Article -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://cluenex.com{{ page.url }}"
      },
      "headline": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ date | isoDate }}",
      "dateModified": "{{ dateModified | isoDate }}",
      "author": {
        "@type": "Organization",
        "name": "{{ author }}",
        "url": "https://cluenex.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Cluenex",
        "url": "https://cluenex.com"
      },
      "articleSection": "{{ category }}",
      "keywords": "{{ keywords | join(', ') }}",
      "inLanguage": "en-US"
    }
    </script>

    <!-- JSON-LD: BreadcrumbList -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://cluenex.com" },
        { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://learn.cluenex.com/learn" },
        { "@type": "ListItem", "position": 3, "name": "{{ category }}", "item": "https://learn.cluenex.com/learn/{{ category | slug }}/" },
        { "@type": "ListItem", "position": 4, "name": "{{ title }}", "item": "https://cluenex.com{{ page.url }}" }
      ]
    }
    </script>

    <!-- JSON-LD: FAQPage (generated from the article's FAQ section) -->
    {% set faqJson = content | faqSchema %}
    {% if faqJson %}
    <script type="application/ld+json">{{ faqJson | safe }}</script>
    {% endif %}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/assets/css/base.css">
</head>
<body>

    <!-- Reading Progress -->
    <div id="progress" role="progressbar" aria-label="Reading progress"></div>

    <!-- SITE NAV -->
    <nav class="site-nav" role="navigation" aria-label="Main navigation">
        <div class="nav-inner">
            <a href="https://learn.cluenex.com" class="site-logo"><img src="/assets/images/logo.png" alt="Cluenex logo" height="40"></a>
            <ul class="nav-links" role="list">
                <li class="nav-dropdown">
                    <button class="nav-toggle" aria-expanded="false">Education</button>
                    <ul class="nav-submenu" role="list">
                        <li><a href="https://learn.cluenex.com/learn/technical-analysis">Technical Analysis</a></li>
                        <li><a href="https://learn.cluenex.com/learn/fundamental-analysis">Fundamental Analysis</a></li>
                        <li><a href="https://learn.cluenex.com/learn/portfolio-management">Portfolio Management</a></li>
                    </ul>
                </li>
                <li class="nav-dropdown">
                    <button class="nav-toggle" aria-expanded="false">Tools</button>
                    <ul class="nav-submenu" role="list">
                        <li><a href="https://learn.cluenex.com/learn/markets">Markets</a></li>
                        <li><a href="#">Screener</a></li>
                        <li><a href="#">Stock Screening</a></li>
                    </ul>
                </li>
                <li class="nav-dropdown">
                    <button class="nav-toggle" aria-expanded="false">Resources</button>
                    <ul class="nav-submenu" role="list">
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Compare</a></li>
                        <li><a href="#">Glossary</a></li>
                        <li><a href="#">Methodology</a></li>
                        <li><a href="#">Smart Money</a></li>
                    </ul>
                </li>
            </ul>
            <div class="nav-cta">
                <a href="https://cluenex.com" class="btn-primary">Start Free</a>
            </div>
        </div>
    </nav>

    <div class="wrap">

        <!-- BREADCRUMB -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="https://learn.cluenex.com">Home</a>
            <span class="breadcrumb-sep" aria-hidden="true">›</span>
            <a href="https://learn.cluenex.com/learn/{{ category | slug }}/" class="breadcrumb-category">{{ category }}</a>
            <span class="breadcrumb-sep" aria-hidden="true">›</span>
            <span class="breadcrumb-cur">{{ title }}</span>
        </nav>

        <!-- ARTICLE HEADER -->
        <header class="article-header">
            <span class="cat-badge">
                {{ category }}
            </span>

            <h1 class="article-title" itemprop="headline">
                {{ title }}
            </h1>

            <div class="article-meta">
                <span>By <strong>{{ author }}</strong></span>
                <span class="meta-sep">·</span>
                <span>Updated <time datetime="{{ date | isoDate }}" itemprop="dateModified">{{ date | dateFilter }}</time></span>
                <span class="meta-sep">·</span>
                <span>{{ readingTime }} min read</span>
                <span class="meta-sep">·</span>
                <span class="meta-url">cluenex.com{{ page.url }}</span>
            </div>

            <p class="article-lead">
                {{ excerpt }}
            </p>
        </header>

        <!-- KEY TAKEAWAYS -->
        {% if keyTakeaways %}
        <aside class="key-takeaways" aria-label="Key Takeaways">
            <div class="kt-header">
                <span class="kt-tag">KEY</span>
                <span class="kt-label">Takeaways</span>
            </div>
            <ul>
                {% for takeaway in keyTakeaways %}
                <li>{{ takeaway | safe }}</li>
                {% endfor %}
            </ul>
        </aside>
        {% endif %}

        <!-- TWO-COLUMN LAYOUT -->
        <div class="article-layout">

            <!-- ARTICLE BODY -->
            <article class="article-body"
                     itemscope itemtype="https://schema.org/Article">

                <meta itemprop="headline" content="{{ title }}">
                <meta itemprop="datePublished" content="{{ date | isoDate }}">
                <meta itemprop="author" content="{{ author }}">
                <meta itemprop="url" content="https://cluenex.com{{ page.url }}">

                {{ content | safe }}

            </article>

            <!-- SIDEBAR - TABLE OF CONTENTS -->
            {% set headings = content | extractHeadings %}
            <aside class="toc-sidebar" aria-label="Table of contents">
                {% if headings.length %}
                <div class="toc-head">On this page</div>
                <nav>
                    <ul class="toc-nav" role="list">
                        {% for h in headings %}
                        <li>
                            <a href="#{{ h.id }}" class="toc-link">
                                <span class="toc-num">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
                                <span>{{ h.text }}</span>
                            </a>
                        </li>
                        {% endfor %}
                    </ul>
                </nav>

                <div class="toc-rule"></div>
                {% endif %}

                <div class="toc-cta">
                    <div class="toc-cta-label">Try Cluenex</div>
                    <p class="toc-cta-text">Track real-time sentiment, valuation, and smart-money signals on the top 1,000+ US-listed stocks.</p>
                    <a href="https://cluenex.com" class="btn-sm">Start Free</a>
                </div>
            </aside>

        </div><!-- /.article-layout -->

        <!-- RELATED ARTICLES -->
        <section class="related" aria-labelledby="related-head">
            <div class="related-head" id="related-head">Continue Learning</div>
            <div class="related-grid">
                {% set sameCat = [] %}
                {% for post in collections.posts %}
                    {% if post.data.category == category and post.url != page.url %}
                        {% set sameCat = (sameCat.push(post), sameCat) %}
                    {% endif %}
                {% endfor %}
                {% set others = [] %}
                {% for post in collections.posts %}
                    {% if post.data.category != category and post.url != page.url %}
                        {% set others = (others.push(post), others) %}
                    {% endif %}
                {% endfor %}
                {% set related = (sameCat.concat(others)) | limit(3) %}
                {% for post in related %}
                <a href="{{ post.url }}" class="related-card">
                    <div class="related-tag">{{ post.data.category }}</div>
                    <div class="related-title">{{ post.data.title }}</div>
                    <div class="related-desc">{{ post.data.excerpt or post.data.description }}</div>
                </a>
                {% endfor %}
            </div>
        </section>

    </div><!-- /.wrap -->

    <!-- SITE FOOTER -->
    <footer class="site-footer">
        <div class="footer-inner">
            <span>
                © 2024 Cluenex ·
                <a href="https://cluenex.com/learn">Learn</a> ·
                <a href="https://cluenex.com">Home</a>
            </span>
            <span>For educational purposes only. Not financial advice.</span>
        </div>
    </footer>

    <script src="/assets/js/main.js"></script>

    <script>
        // Nav dropdown toggle for mobile
        document.querySelectorAll('.nav-toggle').forEach(toggle => {
            toggle.addEventListener('click', (e) => {
                e.preventDefault();
                const dropdown = toggle.parentElement;
                const submenu = dropdown.querySelector('.nav-submenu');
                if (submenu) {
                    submenu.style.opacity = submenu.style.opacity === '1' ? '0' : '1';
                    submenu.style.visibility = submenu.style.visibility === 'visible' ? 'hidden' : 'visible';
                }
            });
        });
    </script>

</body>
</html>
